{
    "typeCheckingMode": "strict",
    "exclude": [
        "**/__pycache__",
        "**/.*",
        "__pypackages__",
        "_build",
        "buck-out",
        "build",
        "dist",
        "node_modules",
        "venv"
    ],
    "extraPaths": [
        ".",
        "src",
    ],
    "autoSearchPaths": false,
    "reportMissingTypeStubs": false
}
