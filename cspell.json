{
    "version": "0.2",
    "language": "en",
    "ignorePaths": [
        ".github",
        ".vscode",
        "pyproject.toml",
        "pyrightconfig.json",
        "configs/**",
        "venv/**",
        "**/__pycache__/**",
        "src/grasp_agents/examples/**",
        "README.md"
    ],
    "dictionaries": [
        "python",
        "softwareTerms"
    ],
    "ignoreWords": [
        "pytest",
        "numpy",
        "pandas",
        "pylance"
    ],
    "words": [
        "acked",
        "acking",
        "acks",
        "acompletion",
        "agentic",
        "AILLM",
        "ANNOT",
        "bwrap",
        "catppuccin",
        "chafa",
        "coro",
        "dedup",
        "dedupe",
        "dones",
        "dtracehelper",
        "e2b",
        "embedders",
        "ename",
        "evalue",
        "evts",
        "fsize",
        "getpgid",
        "Ghostty",
        "halfcell",
        "iopub",
        "ipykernel",
        "ipynb",
        "iTerm",
        "jupyter",
        "kernelspec",
        "killpg",
        "Kitty",
        "litellm",
        "llms",
        "logp",
        "macchiato",
        "microvm",
        "monokai",
        "mult",
        "nbformat",
        "pbar",
        "pgid",
        "procs",
        "quiesces",
        "redef",
        "reinject",
        "rlimit",
        "rlimits",
        "sbpl",
        "seatbelt",
        "setrlimit",
        "setsid",
        "sixel",
        "srvtoolu",
        "subprocs",
        "subshell",
        "templ",
        "TGP",
        "tobytes",
        "toolu",
        "uncontained",
        "undeliver",
        "unflushed",
        "unparseable",
        "unprocess",
        "unrepresentable",
        "unsandboxed",
        "unwedges",
        "WezTerm",
        "zmq"
    ],
    "patterns": [
        {
            "name": "ignoreHex",
            "pattern": "0x[0-9a-fA-F]+"
        }
    ],
    "allowCompoundWords": true
}
